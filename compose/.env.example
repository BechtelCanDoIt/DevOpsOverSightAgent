# Copy to compose/.env (gitignored) and fill in. Phase 2 runs with the defaults
# below and NO SaaS creds (collector exports to debug). Add the Splunk/Datadog
# values + enable the exporters in otel-collector/config.yaml for Phase 1.

# --- Mesh / chaos -----------------------------------------------------------
CHAOS_TOKEN=dev-chaos-token
# Short git SHA stamped into traces as git.commit (optional; defaults to "unknown").
# Set when building:  GIT_COMMIT=$(git rev-parse --short HEAD) docker compose ... build
GIT_COMMIT=unknown

# --- Postgres ---------------------------------------------------------------
POSTGRES_PASSWORD=pocpass

# --- Datadog (Phase 1) ------------------------------------------------------
DD_API_KEY=
DD_APP_KEY=
DD_SITE=datadoghq.com

# --- Splunk Cloud HEC (Phase 1) ---------------------------------------------
SPLUNK_HEC_URL=https://http-inputs-<stack>.splunkcloud.com:443/services/collector
SPLUNK_HEC_TOKEN=
SPLUNK_INDEX=main

# --- MCP server / DevOps agent (Phase 3 + 4) --------------------------------
# Base URL of the Splunk Cloud instance used by the Ballerina MCP server
SPLUNK_URL=https://your-splunk.splunkcloud.com
# Anthropic API key for the DevOps agent
ANTHROPIC_API_KEY=
# Override MCP endpoint URLs (defaults point at the in-compose mock services)
SPLUNK_MCP_URL=
DATADOG_MCP_URL=
BALLERINA_TOPOLOGY_MCP_URL=
