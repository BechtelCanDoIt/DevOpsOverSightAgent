# Copy to compose/.env (gitignored) and fill in. The default stack runs with
# these defaults and NO SaaS creds (collector exports to debug). Add the
# Splunk/Datadog values and use the docker-compose.saas.yml overlay for the
# real fan-out.
#
# Host ports in this stack are 1-prefixed so it runs SIDE-BY-SIDE with the
# Ballerina "MCP Best Practices Approach" stack (chaos 19191-19197, agent 18092,
# mocks 18400/18401, OTLP 14317, postgres 15432, ...).

# --- Mesh / chaos -----------------------------------------------------------
CHAOS_TOKEN=dev-chaos-token

# --- Postgres ---------------------------------------------------------------
POSTGRES_PASSWORD=pocpass

# --- Load generator ---------------------------------------------------------
LOADGEN_PATTERN=baseline

# --- Datadog (SaaS overlay) -------------------------------------------------
DD_API_KEY=
DD_APP_KEY=
DD_SITE=datadoghq.com

# --- Splunk Cloud HEC (SaaS overlay) ----------------------------------------
SPLUNK_HEC_URL=https://http-inputs-<stack>.splunkcloud.com:443/services/collector
SPLUNK_HEC_TOKEN=
SPLUNK_INDEX=main
# Base URL of the Splunk instance, used to build correlate_trace search links.
SPLUNK_URL=https://your-splunk.splunkcloud.com

# --- LLM backend (all three agents) -----------------------------------------
# LLM_PROVIDER: anthropic (default) | ollama (creds-free) | openai | amp
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-sonnet-4-6
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:9b
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o

# --- Token/timing capture (parity with the Ballerina stack) -----------------
CSV_MCP_PROXY=FALSE
CSV_MCP_PROXY_PATH=ollama_tokens_mcp_proxy.csv

# --- MCP / A2A endpoints (default to in-compose services; swap for live) -----
# DATADOG_MCP_URL=https://mcp.datadoghq.com/mcp
# DATADOG_MCP_HEADERS=DD-API-KEY=...,DD-APPLICATION-KEY=...
# SPLUNK_MCP_URL=https://<stack>.splunkcloud.com/mcp
# SPLUNK_MCP_TOKEN=...
